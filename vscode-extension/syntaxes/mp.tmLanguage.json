{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MP Language",
  "scopeName": "source.mp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mp",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mp",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mp",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.mp",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.mp",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mp",
          "match": "\\b(if|else|while|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.mp",
          "match": "\\b(let|fn)\\b"
        },
        {
          "name": "constant.language.boolean.mp",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.mp",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.mp",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.mp",
          "match": "(=)"
        },
        {
          "name": "keyword.operator.access.mp",
          "match": "(:)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.mp",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.mp" },
            "2": { "name": "entity.name.function.mp" }
          }
        },
        {
          "name": "support.function.builtin.mp",
          "match": "\\b(print|input|len|type|str|int|float|random|push|pop)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.object.property.mp",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=:)"
        },
        {
          "name": "variable.array.index.mp",
          "match": "\\[\\d+\\]"
        },
        {
          "name": "variable.other.mp",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?!\\s*\\()"
        }
      ]
    }
  }
}
