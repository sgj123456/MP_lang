let i = 0;
while i < 5 {
    print("i =", i)
    i = i + 1
}
let count = 0;
while count < 3 {
    print("Counting:", count)
    count = count + 1
}
let sum = 0;
let n = 1;
while n <= 10 {
    sum = sum + n
    n = n + 1
}
print("Sum of 1 to 10:", sum)
let numbers = [1, 2, 3, 4, 5];
let idx = 0;
while idx < len(numbers) {
    print("numbers[", idx, "] =", numbers[idx])
    idx = idx + 1
}
